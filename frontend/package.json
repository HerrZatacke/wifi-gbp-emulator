{
  "name": "wifi-gbp-emulator-frontend",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "npm run build:clean && npm run build:build && npm run build:shorten",
    "build:build": "tsc && vite build",
    "build:clean": "rimraf ../fs-out && rimraf ../wifi-gbp-emulator/data/w",
    "build:shorten": "node ./scripts/shortenStatic.mjs",
    "dumps:md": "md ..\\wifi-gbp-emulator\\data\\d",
    "dumps:copy": "copy ..\\assets\\*.bin ..\\wifi-gbp-emulator\\data\\d\\",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-plugin-import": "^2.32.0",
    "file-saver": "^2.0.5",
    "globals": "^17.4.0",
    "globby": "^16.2.0",
    "ofetch": "^1.5.1",
    "reset-css": "^5.0.2",
    "rimraf": "^6.1.3",
    "sass": "^1.99.0",
    "sass-embedded": "^1.99.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.7"
  }
}
